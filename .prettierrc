{
    "tabWidth": 2,
    "proseWrap": "always",
    "arrowParens": "avoid",
    "jsxBracketSameLine": false,
    "printWidth": 120,
    "useTabs": false,
    "vueIndentScriptAndStyle": false,
    "trailingComma": "none",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "singleQuote": true,
    "semi": false,
    "htmlWhitespaceSensitivity": "ignore",
    "useEditorConfig": false,
    "singleAttributePerLine": false,
    "endOfLine": "lf"
  }
  